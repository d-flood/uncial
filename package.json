{
	"name": "uncial",
	"version": "0.0.2",
	"packageManager": "bun@1.3.10",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/d-flood/uncial.git"
	},
	"bugs": {
		"url": "https://github.com/d-flood/uncial/issues"
	},
	"homepage": "https://d-flood.github.io/uncial/",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "bunx svelte-kit sync || true",
		"package": "svelte-kit sync && svelte-package",
		"prepack": "bun run package && bunx publint",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run prepack && changeset publish",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --project server",
		"test:browser": "vitest --project client",
		"test": "bun run test:unit -- --run && bun run test:browser -- --run && bun run test:e2e",
		"test:e2e": "playwright test"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css",
		"./dist/web-components/index.js"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"svelte": "./dist/core/index.js",
			"default": "./dist/core/index.js"
		},
		"./editor": {
			"types": "./dist/editor/index.d.ts",
			"svelte": "./dist/editor/index.js",
			"default": "./dist/editor/index.js"
		},
		"./render": {
			"types": "./dist/render/index.d.ts",
			"svelte": "./dist/render/index.js",
			"default": "./dist/render/index.js"
		},
		"./runtime/svelte": {
			"types": "./dist/runtime/svelte.d.ts",
			"svelte": "./dist/runtime/svelte.js",
			"default": "./dist/runtime/svelte.js"
		},
		"./web-components": {
			"types": "./dist/web-components/index.d.ts",
			"svelte": "./dist/web-components/index.js",
			"default": "./dist/web-components/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.0.18",
		"daisyui": "^5.5.19",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"publint": "^0.3.17",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@tiptap/core": "^3.20.0",
		"@tiptap/extension-code-block-lowlight": "3.20.0",
		"@tiptap/html": "^3.20.0",
		"@tiptap/pm": "^3.20.0",
		"@tiptap/starter-kit": "^3.20.0",
		"lowlight": "^3.3.0",
		"phosphor-svelte": "^3.1.0"
	}
}
